                        <p class="text-2xl font-bold text-blue-600">{{ avg_margin }}%</p>
                        <p class="text-xs text-gray-600 mt-1">Avg Margin</p>
                        <p class="text-xs text-blue-500 font-medium">From Billing</p>
                    </div>

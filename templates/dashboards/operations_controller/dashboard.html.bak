        </div>

        <!-- Monthly Billing Approvals Section -->
        <div class="bg-white rounded-xl shadow-md p-6 mb-8">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-bold text-gray-900 flex items-center">
                    <svg class="h-5 w-5 text-purple-600 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    Monthly Billing Approvals
                </h3>
                <form method="get" class="flex items-center space-x-2">
                    <!-- Preserve selected_date for daily operations and selected_month for monthly operations -->
                    <input type="hidden" name="selected_date" value="{{ selected_date|date:'Y-m-d' }}">
                    <input type="hidden" name="selected_month" value="{{ selected_month_start|date:'Y-m' }}">
                    <label for="billing_month" class="text-sm text-gray-600">Month:</label>
                    <input
                        type="month"
                        id="billing_month"
                        name="billing_month"
                        value="{{ billing_month_start|date:'Y-m' }}"
                        max="{{ today|date:'Y-m' }}"
                        class="px-3 py-1 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-purple-500"
                        onchange="this.form.submit()"
                    >
                    <button type="button" onclick="document.getElementById('billing_month').value='{{ today|date:'Y-m' }}'; this.form.submit();" class="px-3 py-1 text-sm bg-purple-500 text-white rounded-lg hover:bg-purple-600">
                        Current Month
                    </button>
                </form>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
                <!-- 1. Controller Approved -->
                <a href="{% url 'operations:monthly_billing_dashboard' %}" class="block group">
                    <div class="text-center p-4 bg-gradient-to-br from-green-50 to-green-100 rounded-lg border border-green-200 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1 cursor-pointer">
                        <p class="text-2xl font-bold text-green-600">{{ controller_approved }}</p>
                        <p class="text-xs text-gray-600 mt-1">Controller Approved</p>
                        <p class="text-xs text-green-500 font-medium">Current Month</p>
                    </div>
                </a>
                <!-- 2. Controller Pending -->
                <a href="{% url 'operations:monthly_billing_dashboard' %}" class="block group">
                    <div class="text-center p-4 bg-gradient-to-br from-yellow-50 to-yellow-100 rounded-lg border border-yellow-200 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1 cursor-pointer">
                        <p class="text-2xl font-bold text-yellow-600">{{ controller_pending }}</p>
                        <p class="text-xs text-gray-600 mt-1">Controller Pending</p>
                        <p class="text-xs text-yellow-500 font-medium">Awaiting Review</p>
                    </div>
                </a>
                <!-- 3. Controller Rejected -->
                <a href="{% url 'operations:monthly_billing_dashboard' %}" class="block group">
                    <div class="text-center p-4 bg-gradient-to-br from-red-50 to-red-100 rounded-lg border border-red-200 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1 cursor-pointer">
                        <p class="text-2xl font-bold text-red-600">{{ controller_rejected }}</p>
                        <p class="text-xs text-gray-600 mt-1">Controller Rejected</p>
                        <p class="text-xs text-red-500 font-medium">Needs Review</p>
                    </div>
                </a>
                <!-- 4. Finance Approved -->
                <a href="{% url 'operations:monthly_billing_dashboard' %}" class="block group">
                    <div class="text-center p-4 bg-gradient-to-br from-emerald-50 to-emerald-100 rounded-lg border border-emerald-200 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1 cursor-pointer">
                        <p class="text-2xl font-bold text-emerald-600">{{ finance_approved }}</p>
                        <p class="text-xs text-gray-600 mt-1">Finance Approved</p>
                        <p class="text-xs text-emerald-500 font-medium">Ready to Invoice</p>
                    </div>
                </a>
                <!-- 5. Finance Pending -->
                <a href="{% url 'operations:monthly_billing_dashboard' %}" class="block group">
                    <div class="text-center p-4 bg-gradient-to-br from-amber-50 to-amber-100 rounded-lg border border-amber-200 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1 cursor-pointer">
                        <p class="text-2xl font-bold text-amber-600">{{ finance_pending }}</p>
                        <p class="text-xs text-gray-600 mt-1">Finance Pending</p>
                        <p class="text-xs text-amber-500 font-medium">In Queue</p>
                    </div>
                </a>
                <!-- 6. Finance Rejected -->
                <a href="{% url 'operations:monthly_billing_dashboard' %}" class="block group">
                    <div class="text-center p-4 bg-gradient-to-br from-rose-50 to-rose-100 rounded-lg border border-rose-200 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1 cursor-pointer">
                        <p class="text-2xl font-bold text-rose-600">{{ finance_rejected }}</p>
                        <p class="text-xs text-gray-600 mt-1">Finance Rejected</p>
                        <p class="text-xs text-rose-500 font-medium">Action Required</p>
                    </div>
                </a>
            </div>
        </div>

        <!-- Adhoc Billing Section -->
        <div class="bg-white rounded-xl shadow-md p-6 mb-8">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-bold text-gray-900 flex items-center">
                    <svg class="h-5 w-5 text-teal-600 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
                    </svg>
                    Adhoc Billing
                </h3>
                <form method="get" class="flex items-center space-x-2">
                    <!-- Preserve other month filters -->
                    <input type="hidden" name="selected_date" value="{{ selected_date|date:'Y-m-d' }}">
                    <input type="hidden" name="selected_month" value="{{ selected_month_start|date:'Y-m' }}">
                    <input type="hidden" name="billing_month" value="{{ billing_month_start|date:'Y-m' }}">
                    <label for="adhoc_month" class="text-sm text-gray-600">Month:</label>
                    <input
                        type="month"
                        id="adhoc_month"
                        name="adhoc_month"
                        value="{{ adhoc_month_start|date:'Y-m' }}"
                        max="{{ today|date:'Y-m' }}"
                        class="px-3 py-1 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-teal-500 focus:border-teal-500"
                        onchange="this.form.submit()"
                    >
                    <button type="button" onclick="document.getElementById('adhoc_month').value='{{ today|date:'Y-m' }}'; this.form.submit();" class="px-3 py-1 text-sm bg-teal-500 text-white rounded-lg hover:bg-teal-600">
                        Current Month
                    </button>
                </form>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
                <!-- 1. Total Entries -->
                <a href="{% url 'operations:adhoc_billing_list' %}" class="block group">
                    <div class="text-center p-4 bg-gradient-to-br from-blue-50 to-blue-100 rounded-lg border border-blue-200 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1 cursor-pointer">
                        <p class="text-2xl font-bold text-blue-600">{{ adhoc_total_count }}</p>
                        <p class="text-xs text-gray-600 mt-1">Total Entries</p>
                        <p class="text-xs text-blue-500 font-medium">All Events</p>
                    </div>
                </a>
                <!-- 2. Total Receivable -->
                <a href="{% url 'operations:adhoc_billing_list' %}" class="block group">
                    <div class="text-center p-4 bg-gradient-to-br from-indigo-50 to-indigo-100 rounded-lg border border-indigo-200 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1 cursor-pointer">
                        <p class="text-2xl font-bold text-indigo-600">₹{{ adhoc_total_receivable_lakhs|floatformat:2|intcomma }}</p>
                        <p class="text-xs text-gray-600 mt-1">Total Receivable</p>
                        <p class="text-xs text-indigo-500 font-medium">In Lakhs</p>
                    </div>
                </a>
                <!-- 3. Total Payable -->
                <a href="{% url 'operations:adhoc_billing_list' %}" class="block group">
                    <div class="text-center p-4 bg-gradient-to-br from-violet-50 to-violet-100 rounded-lg border border-violet-200 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1 cursor-pointer">
                        <p class="text-2xl font-bold text-violet-600">₹{{ adhoc_total_payable_lakhs|floatformat:2|intcomma }}</p>
                        <p class="text-xs text-gray-600 mt-1">Total Payable</p>
                        <p class="text-xs text-violet-500 font-medium">In Lakhs</p>
                    </div>
                </a>
                <!-- 4. By Event Type -->
                <a href="{% url 'operations:adhoc_billing_list' %}" class="block group">
                    <div class="text-center p-4 bg-gradient-to-br from-purple-50 to-purple-100 rounded-lg border border-purple-200 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1 cursor-pointer">
                        <p class="text-2xl font-bold text-purple-600">{{ adhoc_most_common_type_count }}</p>
                        <p class="text-xs text-gray-600 mt-1">{{ adhoc_most_common_type }}</p>
                        <p class="text-xs text-purple-500 font-medium">Most Common</p>
                    </div>
                </a>
                <!-- 5. High Value Entries -->
                <a href="{% url 'operations:adhoc_billing_list' %}" class="block group">
                    <div class="text-center p-4 bg-gradient-to-br from-amber-50 to-amber-100 rounded-lg border border-amber-200 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1 cursor-pointer">
                        <p class="text-2xl font-bold text-amber-600">{{ adhoc_high_value_count }}</p>
                        <p class="text-xs text-gray-600 mt-1">High Value Entries</p>
                        <p class="text-xs text-amber-500 font-medium">>₹1 Lakh</p>
                    </div>
                </a>
                <!-- 6. Aging (Not Billed) -->
                <a href="{% url 'operations:adhoc_billing_list' %}" class="block group">
                    <div class="text-center p-4 bg-gradient-to-br from-red-50 to-red-100 rounded-lg border border-red-200 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1 cursor-pointer">
                        <p class="text-2xl font-bold text-red-600">{{ adhoc_aging_count }}</p>
                        <p class="text-xs text-gray-600 mt-1">Aging</p>
                        <p class="text-xs text-red-500 font-medium">Not Yet Billed</p>
                    </div>
                </a>
            </div>
        </div>

        <!-- MIS Metrics Section -->
        <div class="bg-white rounded-xl shadow-md p-6 mb-8">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-bold text-gray-900 flex items-center">
                    <svg class="h-5 w-5 text-blue-600 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                    </svg>
                    MIS Metrics
                </h3>
                <form method="get" class="flex items-center space-x-2">
                    <!-- Preserve other month filters -->
                    <input type="hidden" name="selected_date" value="{{ selected_date|date:'Y-m-d' }}">
                    <input type="hidden" name="selected_month" value="{{ selected_month_start|date:'Y-m' }}">
                    <input type="hidden" name="billing_month" value="{{ billing_month_start|date:'Y-m' }}">
                    <input type="hidden" name="adhoc_month" value="{{ adhoc_month_start|date:'Y-m' }}">
                    <label for="mis_month" class="text-sm text-gray-600">Month:</label>
                    <input
                        type="month"
                        id="mis_month"
                        name="mis_month"
                        value="{{ mis_month_start|date:'Y-m' }}"
                        max="{{ today|date:'Y-m' }}"
                        class="px-3 py-1 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                        onchange="this.form.submit()"
                    >
                    <button type="button" onclick="document.getElementById('mis_month').value='{{ today|date:'Y-m' }}'; this.form.submit();" class="px-3 py-1 text-sm bg-blue-500 text-white rounded-lg hover:bg-blue-600">
                        Current Month
                    </button>
                </form>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
                <!-- 1. MIS Pending Today -->
                <div class="block group">
                    <div class="text-center p-4 bg-gradient-to-br from-red-50 to-red-100 rounded-lg border border-red-200 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1">
                        <p class="text-2xl font-bold text-red-600">{{ mis_pending_count }}</p>
                        <p class="text-xs text-gray-600 mt-1">MIS Pending Today</p>
                        <p class="text-xs text-red-500 font-medium">Missing Entries</p>
                    </div>
                </div>
                <!-- 2. Projects with MIS Daily -->
                <div class="block group">
                    <div class="text-center p-4 bg-gradient-to-br from-blue-50 to-blue-100 rounded-lg border border-blue-200 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1">
                        <p class="text-2xl font-bold text-blue-600">{{ mis_daily_projects }}</p>
                        <p class="text-xs text-gray-600 mt-1">MIS Daily</p>
                        <p class="text-xs text-blue-500 font-medium">Projects</p>
                    </div>
                </div>
                <!-- 3. Projects with MIS Weekly -->
                <div class="block group">
                    <div class="text-center p-4 bg-gradient-to-br from-purple-50 to-purple-100 rounded-lg border border-purple-200 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1">
                        <p class="text-2xl font-bold text-purple-600">{{ mis_weekly_projects }}</p>
                        <p class="text-xs text-gray-600 mt-1">MIS Weekly</p>
                        <p class="text-xs text-purple-500 font-medium">Projects</p>
                    </div>
                </div>
                <!-- 4. Projects with MIS Monthly -->
                <div class="block group">
                    <div class="text-center p-4 bg-gradient-to-br from-indigo-50 to-indigo-100 rounded-lg border border-indigo-200 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1">
                        <p class="text-2xl font-bold text-indigo-600">{{ mis_monthly_projects }}</p>
                        <p class="text-xs text-gray-600 mt-1">MIS Monthly</p>
                        <p class="text-xs text-indigo-500 font-medium">Projects</p>
                    </div>
                </div>
                <!-- 5. Projects >3 Missing -->

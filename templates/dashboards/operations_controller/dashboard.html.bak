                <a href="{% url 'accounts:monthly_max_inventory_detail' %}?selected_month={{ selected_month_start|date:'Y-m' }}" class="block group">
                    <div class="text-center p-4 bg-gradient-to-br from-amber-50 to-amber-100 rounded-lg border border-amber-200 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1 cursor-pointer">
                        <p class="text-2xl font-bold text-amber-600">₹{{ max_inventory_month_crores|floatformat:2 }}</p>

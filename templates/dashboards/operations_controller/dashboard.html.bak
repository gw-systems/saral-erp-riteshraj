                    <div class="text-center p-4 bg-gradient-to-br from-amber-50 to-amber-100 rounded-lg border border-amber-200 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1">
                        <p class="text-2xl font-bold text-amber-600">{{ projects_with_high_mis_gaps }}</p>
                        <p class="text-xs text-gray-600 mt-1">Projects >3 Missing</p>
                        <p class="text-xs text-amber-500 font-medium">High Gaps</p>
                    </div>
                </div>
                <!-- 6. Team Avg Completion -->
                <div class="block group">
                    <div class="text-center p-4 bg-gradient-to-br from-green-50 to-green-100 rounded-lg border border-green-200 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1">
                        <p class="text-2xl font-bold text-green-600">{{ team_avg_mis_completion }}%</p>
                        <p class="text-xs text-gray-600 mt-1">Team Avg Completion</p>
                        <p class="text-xs text-green-500 font-medium">Overall Rate</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Row 4: Adhoc Billing ↔ Monthly Billing -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">

            <!-- Left: Adhoc Billing -->
            <div class="bg-white rounded-xl shadow-md overflow-hidden">
                <div class="bg-gradient-to-r from-orange-500 to-orange-600 px-6 py-4">
                    <h3 class="text-lg font-bold text-white flex items-center">
                        <svg class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        Adhoc Billing
                    </h3>
                </div>
                <div class="p-6">
                    <div class="grid grid-cols-3 gap-4">
                        <div class="text-center">
                            <p class="text-2xl font-bold text-orange-600">{{ adhoc_pending }}</p>
                            <p class="text-xs text-gray-600 mt-1">Pending</p>
                        </div>
                        <div class="text-center">
                            <p class="text-2xl font-bold text-green-600">{{ adhoc_approved_month }}</p>
                            <p class="text-xs text-gray-600 mt-1">Approved</p>
                        </div>
                        <div class="text-center">
                            <p class="text-2xl font-bold text-blue-600">{{ adhoc_billed_month }}</p>

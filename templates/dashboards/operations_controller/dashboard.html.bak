                        </div>
                    </div>
                    <div class="mt-4 pt-4 border-t border-gray-200">
                        <div class="flex justify-between items-center">
                            <span class="text-sm text-gray-600">Pending Amount</span>
                            <span class="text-lg font-bold text-orange-600">₹{{ adhoc_pending_amount|floatformat:2 }}L</span>
                        </div>
                        <div class="flex justify-between items-center mt-2">
                            <span class="text-sm text-gray-600">Aging (>30 days)</span>
                            <span class="text-lg font-bold text-red-600">{{ adhoc_pending_old }}</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right: Monthly Billing -->
            <div class="bg-white rounded-xl shadow-md overflow-hidden">
                <div class="bg-gradient-to-r from-teal-500 to-teal-600 px-6 py-4">
                    <h3 class="text-lg font-bold text-white flex items-center">
                        <svg class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z"/>
                        </svg>
                        Monthly Billing
                    </h3>
                </div>
                <div class="p-6">
                    <div class="grid grid-cols-3 gap-4">
                        <div class="text-center">
                            <p class="text-2xl font-bold text-orange-600">{{ billing_pending }}</p>
                            <p class="text-xs text-gray-600 mt-1">Pending</p>
                        </div>
                        <div class="text-center">
                            <p class="text-2xl font-bold text-blue-600">{{ billing_sent }}</p>
                            <p class="text-xs text-gray-600 mt-1">Sent</p>
                        </div>
                        <div class="text-center">
                            <p class="text-2xl font-bold text-green-600">{{ billing_paid }}</p>
                            <p class="text-xs text-gray-600 mt-1">Paid</p>
                        </div>
                    </div>

                    <!-- Controller Approval Breakdown -->
                    <div class="mt-4 pt-4 border-t border-gray-200">
                        <p class="text-xs font-semibold text-gray-700 mb-3">Controller Approvals</p>
                        <div class="grid grid-cols-3 gap-3">
                            <div class="text-center p-2 bg-green-50 rounded">
                                <p class="text-lg font-bold text-green-600">{{ controller_approved }}</p>
                                <p class="text-xs text-gray-600">Approved</p>
                            </div>
                            <div class="text-center p-2 bg-red-50 rounded">
                                <p class="text-lg font-bold text-red-600">{{ controller_rejected }}</p>
                                <p class="text-xs text-gray-600">Rejected</p>
                            </div>
                            <div class="text-center p-2 bg-yellow-50 rounded">
                                <p class="text-lg font-bold text-yellow-600">{{ controller_pending }}</p>
                                <p class="text-xs text-gray-600">Pending</p>
                            </div>
                        </div>
                    </div>

                    <!-- Finance Approval Breakdown -->
                    <div class="mt-3 pt-3 border-t border-gray-200">
                        <p class="text-xs font-semibold text-gray-700 mb-3">Finance Approvals</p>
                        <div class="grid grid-cols-3 gap-3">
                            <div class="text-center p-2 bg-green-50 rounded">
                                <p class="text-lg font-bold text-green-600">{{ finance_approved }}</p>
                                <p class="text-xs text-gray-600">Approved</p>
                            </div>
                            <div class="text-center p-2 bg-red-50 rounded">
                                <p class="text-lg font-bold text-red-600">{{ finance_rejected }}</p>
                                <p class="text-xs text-gray-600">Rejected</p>
                            </div>
                            <div class="text-center p-2 bg-yellow-50 rounded">
                                <p class="text-lg font-bold text-yellow-600">{{ finance_pending }}</p>
                                <p class="text-xs text-gray-600">Pending</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- Row 5: Disputes ↔ MIS Metrics -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">

            <!-- Left: Disputes -->
            <div class="bg-white rounded-xl shadow-md overflow-hidden">
                <div class="bg-gradient-to-r from-red-500 to-red-600 px-6 py-4">
                    <h3 class="text-lg font-bold text-white flex items-center">
                        <svg class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                        </svg>
                        Disputes Overview
                    </h3>
                </div>
                <div class="p-6">
                    <div class="grid grid-cols-3 gap-4">
                        <div class="text-center">
                            <p class="text-2xl font-bold text-red-600">{{ open_disputes }}</p>
                            <p class="text-xs text-gray-600 mt-1">Open</p>
                        </div>
                        <div class="text-center">
                            <p class="text-2xl font-bold text-amber-600">{{ in_progress_disputes }}</p>
                            <p class="text-xs text-gray-600 mt-1">In Progress</p>
                        </div>
                        <div class="text-center">
                            <p class="text-2xl font-bold text-green-600">{{ resolved_disputes_month }}</p>
                            <p class="text-xs text-gray-600 mt-1">Resolved</p>
                        </div>
                    </div>
                    <div class="mt-4 pt-4 border-t border-gray-200">
                        <div class="flex justify-between items-center">
                            <span class="text-sm text-gray-600">Critical (>30 days)</span>
                            <span class="text-lg font-bold text-red-600">{{ critical_disputes }}</span>
                        </div>
                        <div class="flex justify-between items-center mt-2">
                            <span class="text-sm text-gray-600">Resolution Rate</span>
                            <span class="text-lg font-bold text-green-600">{{ dispute_resolution_rate }}%</span>
                        </div>
                        <div class="flex justify-between items-center mt-2">
                            <span class="text-sm text-gray-600">Avg Resolution Time</span>
                            <span class="text-lg font-bold text-blue-600">{{ avg_resolution_time }} days</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right: MIS Metrics -->
            <div class="bg-white rounded-xl shadow-md overflow-hidden">
                <div class="bg-gradient-to-r from-purple-500 to-purple-600 px-6 py-4">
                    <h3 class="text-lg font-bold text-white flex items-center">
                        <svg class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                        </svg>
                        MIS Metrics
                    </h3>
                </div>
                <div class="p-6">
                    <div class="space-y-3">
                        <div class="flex justify-between items-center p-3 bg-red-50 rounded-lg">
                            <span class="text-sm font-medium text-gray-700">MIS Pending Today</span>
                            <span class="text-xl font-bold text-red-600">{{ mis_pending_count }}</span>
                        </div>
                        <div class="flex justify-between items-center p-3 bg-amber-50 rounded-lg">
                            <span class="text-sm font-medium text-gray-700">Projects with >3 Missing</span>
                            <span class="text-xl font-bold text-amber-600">{{ projects_with_high_mis_gaps }}</span>
                        </div>
                        <div class="flex justify-between items-center p-3 bg-orange-50 rounded-lg">
                            <span class="text-sm font-medium text-gray-700">Low Compliance Coords (<90%)</span>
                            <span class="text-xl font-bold text-orange-600">{{ low_compliance_coordinators }}</span>
                        </div>
                        <div class="flex justify-between items-center p-3 bg-blue-50 rounded-lg">
                            <span class="text-sm font-medium text-gray-700">Team Avg Completion</span>
                            <span class="text-xl font-bold text-blue-600">{{ team_avg_mis_completion }}%</span>
                        </div>
                        <div class="flex justify-between items-center p-3 bg-purple-50 rounded-lg">
                            <span class="text-sm font-medium text-gray-700">Max Consecutive Gap</span>
                            <span class="text-xl font-bold text-purple-600">{{ consecutive_missing_days }} days</span>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- Row 6: Top States ↔ Top Clients -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

            <!-- Left: Top States -->
            <div class="bg-white rounded-xl shadow-md overflow-hidden">
                <div class="bg-gradient-to-r from-blue-500 to-blue-600 px-6 py-4">
                    <h3 class="text-lg font-bold text-white flex items-center">
                        <svg class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                        Top States (Active Projects)
                    </h3>
                </div>
                <div class="p-6">
                    <div class="space-y-2">
                        {% for state in top_states %}
                        <a href="{% url 'projects:project_list_all' %}?state={{ state.name }}" class="flex items-center justify-between p-3 bg-gradient-to-r from-blue-50 to-white rounded-lg hover:shadow-md transition-shadow border border-blue-100">
                            <span class="font-medium text-gray-800">{{ state.name }}</span>
                            <div class="flex items-center space-x-2">
                                <span class="text-sm text-gray-600">{{ state.count }} projects</span>
                                <div class="w-16 bg-gray-200 rounded-full h-2">
                                    <div class="bg-blue-600 h-2 rounded-full" style="width: {% widthratio state.count active_projects 100 %}%"></div>
                                </div>
                            </div>
                        </a>
                        {% empty %}
                        <p class="text-sm text-gray-500 text-center py-4">No data available</p>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <!-- Right: Top Clients -->
            <div class="bg-white rounded-xl shadow-md overflow-hidden">
                <div class="bg-gradient-to-r from-green-500 to-green-600 px-6 py-4">
                    <h3 class="text-lg font-bold text-white flex items-center">
                        <svg class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                        </svg>
                        Top Clients (Active + Pending)
                    </h3>
                </div>
                <div class="p-6">
                    <div class="space-y-2">
                        {% for client in top_clients %}
                        <a href="{% url 'projects:project_list_all' %}?client={{ client.name }}" class="flex items-center justify-between p-3 bg-gradient-to-r from-green-50 to-white rounded-lg hover:shadow-md transition-shadow border border-green-100">
                            <div class="flex items-center space-x-3">
                                <span class="flex items-center justify-center w-6 h-6 rounded-full bg-green-600 text-white text-xs font-bold">{{ client.rank }}</span>
                                <span class="font-medium text-gray-800">{{ client.name }}</span>
                            </div>
                            <div class="flex items-center space-x-2">
                                <span class="text-sm text-gray-600">{{ client.projects }} projects</span>
                                <div class="w-16 bg-gray-200 rounded-full h-2">
                                    <div class="bg-green-600 h-2 rounded-full" style="width: {% widthratio client.projects active_projects 100 %}%"></div>
                                </div>
                            </div>
                        </a>
                        {% empty %}
                        <p class="text-sm text-gray-500 text-center py-4">No data available</p>
                        {% endfor %}
                    </div>
                </div>
            </div>

        </div>

    </div>

</div>

{% endblock %}

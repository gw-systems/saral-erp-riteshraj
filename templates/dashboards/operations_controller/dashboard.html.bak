                <a href="{% url 'accounts:monthly_max_inventory_detail' %}?selected_month={{ selected_month_start|date:'Y-m' }}" class="block group">
                    <div class="text-center p-4 bg-gradient-to-br from-teal-50 to-teal-100 rounded-lg border border-teal-200 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1 cursor-pointer">

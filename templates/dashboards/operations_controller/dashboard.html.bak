                        <p class="text-xs text-gray-600 mt-1">Adhoc Billing</p>
                        <p class="text-xs text-orange-500 font-medium">₹{{ adhoc_month_value_lakhs|floatformat:2 }}L</p>
                    </div>
                </a>
                <!-- 2. Total Monthly Billing -->
                <a href="{% url 'operations:monthly_billing_dashboard' %}" class="block group">
                    <div class="text-center p-4 bg-gradient-to-br from-green-50 to-green-100 rounded-lg border border-green-200 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1 cursor-pointer">
                        <p class="text-2xl font-bold text-green-600">{{ monthly_billing_count }}</p>
                        <p class="text-xs text-gray-600 mt-1">Monthly Billing</p>
                        <p class="text-xs text-green-500 font-medium">₹{{ monthly_billing_value_lakhs|floatformat:2 }}L</p>
                    </div>

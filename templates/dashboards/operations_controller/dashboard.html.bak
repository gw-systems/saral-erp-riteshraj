{% extends 'base.html' %}
{% load static %}
{% load humanize %}

{% block title %}Operation Controller Dashboard - {{ APP_FULL_NAME }}{% endblock %}

{% block extra_css %}
<style>
    .text-xxs {
        font-size: 0.65rem;
        line-height: 1rem;
    }
</style>
{% endblock %}

{% block content %}

<div class="min-h-screen bg-gradient-to-br from-gray-50 to-gray-100">

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

        <!-- Stats Grid - 6x2 Matrix (12 Cards) -->
        <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-8">

            <!-- Row 1: Core Metrics -->

            <!-- 1. Total Projects -->
            <a href="{% url 'projects:project_list_all' %}" class="block group">
                <div class="bg-gradient-to-br from-blue-400 to-blue-500 rounded-xl shadow-md hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 cursor-pointer p-5">
                    <div class="text-white">
                        <div class="flex items-center justify-between mb-2">
                            <p class="text-xs font-semibold text-blue-50 uppercase">Total</p>
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
                            </svg>
                        </div>
                        <p class="text-2xl font-bold mb-1">{{ total_projects_card }}</p>
                        <p class="text-xs text-blue-50">Projects</p>
                    </div>
                </div>
            </a>

            <!-- 2. Active Projects -->
            <a href="{% url 'projects:project_list_active' %}" class="block group">
                <div class="bg-gradient-to-br from-green-400 to-green-500 rounded-xl shadow-md hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 cursor-pointer p-5">
                    <div class="text-white">
                        <div class="flex items-center justify-between mb-2">
                            <p class="text-xs font-semibold text-green-50 uppercase">Active</p>
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                        </div>
                        <p class="text-2xl font-bold mb-1">{{ active_projects }}</p>
                        <p class="text-xs text-green-50">Projects</p>
                    </div>
                </div>
            </a>

            <!-- 3. Not Started Projects -->
            <a href="{% url 'projects:project_list_pending' %}" class="block group">
                <div class="bg-gradient-to-br from-amber-400 to-amber-500 rounded-xl shadow-md hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 cursor-pointer p-5">
                    <div class="text-white">
                        <div class="flex items-center justify-between mb-2">
                            <p class="text-xs font-semibold text-amber-50 uppercase">Not Started</p>
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                        </div>
                        <p class="text-2xl font-bold mb-1">{{ not_started_projects }}</p>
                        <p class="text-xs text-amber-50">Projects</p>
                    </div>
                </div>
            </a>

            <!-- 4. Clients -->
            <a href="{% url 'projects:client_card_list' %}" class="block group">
                <div class="bg-gradient-to-br from-cyan-400 to-cyan-500 rounded-xl shadow-md hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 cursor-pointer p-5">
                    <div class="text-white">
                        <div class="flex items-center justify-between mb-2">
                            <p class="text-xs font-semibold text-cyan-50 uppercase">Clients</p>
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                            </svg>
                        </div>
                        <p class="text-2xl font-bold mb-1">{{ total_clients }}</p>
                        <p class="text-xs text-cyan-50">Active</p>
                    </div>
                </div>
            </a>

            <!-- 5. Vendors -->
            <a href="{% url 'supply:vendor_list' %}" class="block group">
                <div class="bg-gradient-to-br from-pink-400 to-pink-500 rounded-xl shadow-md hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 cursor-pointer p-5">
                    <div class="text-white">
                        <div class="flex items-center justify-between mb-2">
                            <p class="text-xs font-semibold text-pink-50 uppercase">Vendors</p>
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                            </svg>
                        </div>
                        <p class="text-2xl font-bold mb-1">{{ total_vendors }}</p>
                        <p class="text-xs text-pink-50">Active</p>
                    </div>
                </div>
            </a>

            <!-- 6. Warehouses -->
            <a href="{% url 'supply:warehouse_list' %}" class="block group">
                <div class="bg-gradient-to-br from-violet-400 to-violet-500 rounded-xl shadow-md hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 cursor-pointer p-5">
                    <div class="text-white">
                        <div class="flex items-center justify-between mb-2">
                            <p class="text-xs font-semibold text-violet-50 uppercase">Warehouses</p>
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                            </svg>
                        </div>
                        <p class="text-2xl font-bold mb-1">{{ total_warehouses }}</p>
                        <p class="text-xs text-violet-50">Active</p>
                    </div>
                </div>
            </a>

            <!-- Row 2: Operations & Billing -->

            <!-- 7. MIS Pending -->
            <a href="{% url 'operations:mis_dashboard' %}" class="block group">
                <div class="bg-gradient-to-br from-purple-400 to-purple-500 rounded-xl shadow-md hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 cursor-pointer p-5">
                    <div class="text-white">
                        <div class="flex items-center justify-between mb-2">
                            <p class="text-xs font-semibold text-purple-50 uppercase">MIS Pending</p>
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                            </svg>
                        </div>
                        <p class="text-2xl font-bold mb-1">{{ mis_pending_count }}</p>
                        <p class="text-xs text-purple-50">Today</p>
                    </div>
                </div>
            </a>

            <!-- 8. Disputes -->
            <a href="{% url 'operations:dispute_list' %}" class="block group">
                <div class="bg-gradient-to-br from-red-400 to-red-500 rounded-xl shadow-md hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 cursor-pointer p-5">
                    <div class="text-white">
                        <div class="flex items-center justify-between mb-2">
                            <p class="text-xs font-semibold text-red-50 uppercase">Disputes</p>
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                            </svg>
                        </div>
                        <p class="text-2xl font-bold mb-1">{{ open_disputes }}</p>
                        <p class="text-xs text-red-50">{{ critical_disputes }} Critical</p>
                    </div>
                </div>
            </a>

            <!-- 9. Adhoc Billing -->
            <a href="{% url 'operations:adhoc_billing_list' %}" class="block group">
                <div class="bg-gradient-to-br from-orange-400 to-orange-500 rounded-xl shadow-md hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 cursor-pointer p-5">
                    <div class="text-white">
                        <div class="flex items-center justify-between mb-2">
                            <p class="text-xs font-semibold text-orange-50 uppercase">Adhoc</p>
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                        </div>
                        <p class="text-2xl font-bold mb-1">{{ adhoc_pending }}</p>
                        <p class="text-xs text-orange-50">₹{{ adhoc_pending_amount|floatformat:2 }}L</p>
                    </div>
                </div>
            </a>

            <!-- 10. Project-Wise Transport -->
            <a href="{% url 'expense_log:transport_projectwise' %}" class="block group">
                <div class="bg-gradient-to-br from-teal-400 to-teal-500 rounded-xl shadow-md hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 cursor-pointer p-5">
                    <div class="text-white">
                        <div class="flex items-center justify-between mb-2 h-5">
                            <p class="text-xxs font-semibold text-teal-50 uppercase leading-tight">Transport<br>Expenses</p>
                            <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1-1V4a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6 0a1 1 0 001 1h2a1 1 0 001-1m0 0h2a2 2 0 002-2v-3m-4 5V9h3"/>
                            </svg>
                        </div>
                        <p class="text-2xl font-bold mb-1">{{ waas_projects_count }}</p>
                        <p class="text-xs text-teal-50">₹{{ transport_approved_amount|floatformat:2|intcomma }}</p>
                    </div>
                </div>
            </a>

            <!-- 11. Team Performance -->
            <a href="{% url 'accounts:operation_controller_team' %}" class="block group">
                <div class="bg-gradient-to-br from-indigo-400 to-indigo-500 rounded-xl shadow-md hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 cursor-pointer p-5">
                    <div class="text-white">
                        <div class="flex items-center justify-between mb-2">
                            <p class="text-xs font-semibold text-indigo-50 uppercase">Team</p>
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                            </svg>
                        </div>
                        <p class="text-2xl font-bold mb-1">{{ team_with_projects }}</p>
                        <p class="text-xs text-indigo-50">{{ team_avg_completion }}%</p>
                    </div>
                </div>
            </a>

            <!-- 12. Tally Connection Status -->
            <div class="block group">
                <div class="bg-gradient-to-br from-gray-400 to-gray-500 rounded-xl shadow-md hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 cursor-pointer p-5">
                    <div class="text-white">
                        <div class="flex items-center justify-between mb-2">
                            <p class="text-xs font-semibold text-gray-50 uppercase">Tally</p>
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
                            </svg>
                        </div>
                        <p class="text-2xl font-bold mb-1">
                            {% if tally_connected %}✓{% else %}✗{% endif %}
                        </p>
                        <p class="text-xs text-gray-50">
                            {% if tally_connected %}Connected{% else %}Not Connected{% endif %}
                        </p>
                    </div>
                </div>
            </div>

        </div>

        <!-- Row 3: Daily Operations (Full Width) -->
        <div class="bg-white rounded-xl shadow-md p-6 mb-8">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-bold text-gray-900 flex items-center">
                    <svg class="h-5 w-5 text-blue-600 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                    </svg>
                    Daily Operations
                </h3>
                <!-- Date Filter -->
                <form method="get" class="flex items-center space-x-2" id="daily-ops-filter-form">
                    <label for="selected_date" class="text-sm text-gray-600">Date:</label>
                    <input
                        type="date"
                        id="selected_date"
                        name="selected_date"
                        value="{{ selected_date|date:'Y-m-d' }}"
                        max="{{ today|date:'Y-m-d' }}"
                        class="px-3 py-1 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                        onchange="this.form.submit()"
                    >
                    <button type="button" onclick="document.getElementById('selected_date').value='{{ today|date:'Y-m-d' }}'; this.form.submit();" class="px-3 py-1 text-sm bg-blue-500 text-white rounded-lg hover:bg-blue-600">
                        Today
                    </button>
                </form>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
                <!-- 1. Missing Entries -->
                <a href="{% url 'accounts:daily_missing_entries_detail' %}?selected_date={{ selected_date|date:'Y-m-d' }}" class="block group">
                    <div class="text-center p-4 bg-gradient-to-br from-red-50 to-red-100 rounded-lg border border-red-200 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1 cursor-pointer">
                        <p class="text-2xl font-bold text-red-600">{{ entries_missing_today }}</p>
                        <p class="text-xs text-gray-600 mt-1">Missing Entries</p>
                        <p class="text-xs text-red-500 font-medium">{{ selected_date|date:"M d, Y" }}</p>
                    </div>
                </a>
                <!-- 2. Total Space -->
                <a href="{% url 'accounts:daily_space_utilization_detail' %}?selected_date={{ selected_date|date:'Y-m-d' }}" class="block group">
                    <div class="text-center p-4 bg-gradient-to-br from-green-50 to-green-100 rounded-lg border border-green-200 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1 cursor-pointer">
                        <p class="text-2xl font-bold text-green-600">{{ total_space_today_lakhs|floatformat:2 }} Sq. Ft.</p>
                        <p class="text-xs text-gray-600 mt-1">Total Space</p>
                        <p class="text-xs text-green-500 font-medium">Lakhs</p>
                    </div>
                </a>
                <!-- 3. Total Inventory -->
                <a href="{% url 'accounts:daily_space_utilization_detail' %}?selected_date={{ selected_date|date:'Y-m-d' }}" class="block group">
                    <div class="text-center p-4 bg-gradient-to-br from-amber-50 to-amber-100 rounded-lg border border-amber-200 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1 cursor-pointer">
                        <p class="text-2xl font-bold text-amber-600">₹{{ total_inventory_today|floatformat:2 }}</p>
                        <p class="text-xs text-gray-600 mt-1">Total Inventory</p>
                        <p class="text-xs text-amber-500 font-medium">Crores</p>
                    </div>
                </a>
                <!-- 4. Space Variance Alerts -->
                <a href="{% url 'accounts:daily_variance_alerts_detail' %}?selected_date={{ selected_date|date:'Y-m-d' }}" class="block group relative">
                    <div class="text-center p-4 bg-gradient-to-br from-orange-50 to-orange-100 rounded-lg border border-orange-200 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1 cursor-pointer">
                        <p class="text-2xl font-bold text-orange-600">{{ space_variance_alerts }}</p>
                        <p class="text-xs text-gray-600 mt-1">Variance Alerts</p>
                        <p class="text-xs text-orange-500 font-medium">>30% Change</p>

                        {% if space_variance_projects %}
                        <!-- Tooltip on hover -->
                        <div class="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 hidden group-hover:block z-50 pointer-events-none">
                            <div class="bg-gray-900 text-white text-sm rounded-lg p-4 shadow-xl w-96">
                                <p class="font-bold mb-3 text-base border-b border-gray-700 pb-2">Projects with >30% Space Change</p>
                                <div class="space-y-2 max-h-64 overflow-y-auto pr-2">
                                    {% for proj in space_variance_projects %}
                                    <div class="border-b border-gray-700 pb-2 mb-2 last:border-b-0">
                                        <div class="flex items-start justify-between mb-1">
                                            <p class="font-bold text-white">{{ proj.project_code }}</p>
                                            <span class="px-2 py-0.5 bg-orange-500 text-white text-xs rounded-full font-semibold">{{ proj.change_pct }}%</span>
                                        </div>
                                        <p class="text-gray-300 text-sm mb-1">{{ proj.client_name }}</p>
                                        <div class="flex items-center justify-between text-xs">
                                            <span class="text-gray-400">Yesterday: {{ proj.yesterday_space|floatformat:0 }} sq ft</span>
                                            <span class="text-gray-500 mx-2">→</span>
                                            <span class="text-gray-400">Today: {{ proj.today_space|floatformat:0 }} sq ft</span>
                                        </div>
                                    </div>
                                    {% endfor %}
                                </div>
                                <div class="absolute top-full left-1/2 transform -translate-x-1/2 w-0 h-0 border-l-8 border-r-8 border-t-8 border-transparent border-t-gray-900"></div>
                            </div>
                        </div>
                        {% endif %}
                    </div>
                </a>
                <!-- 5. Inventory Turnover -->
                <a href="{% url 'accounts:daily_inventory_turnover_detail' %}?selected_date={{ selected_date|date:'Y-m-d' }}" class="block group">
                    <div class="text-center p-4 bg-gradient-to-br from-purple-50 to-purple-100 rounded-lg border border-purple-200 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1 cursor-pointer">
                        <p class="text-2xl font-bold {% if inventory_turnover > 0 %}text-green-600{% elif inventory_turnover < 0 %}text-red-600{% else %}text-gray-600{% endif %}">
                            {% if inventory_turnover > 0 %}+{% endif %}{{ inventory_turnover|floatformat:2 }}%
                        </p>
                        <p class="text-xs text-gray-600 mt-1">Inventory Turnover</p>
                        <p class="text-xs text-purple-500 font-medium">vs Previous Day</p>
                    </div>
                </a>
                <!-- 6. Data Quality Score -->
                <div class="block group">
                    <div class="text-center p-4 bg-gradient-to-br from-blue-50 to-blue-100 rounded-lg border border-blue-200 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1">
                        <p class="text-2xl font-bold {% if data_quality_score_daily >= 90 %}text-green-600{% elif data_quality_score_daily >= 75 %}text-blue-600{% elif data_quality_score_daily >= 50 %}text-orange-600{% else %}text-red-600{% endif %}">
                            {{ data_quality_score_daily }}%
                        </p>
                        <p class="text-xs text-gray-600 mt-1">Data Quality</p>
                        <p class="text-xs text-blue-500 font-medium">Entry Compliance</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Monthly Operations Section -->
        <div class="bg-white rounded-xl shadow-md p-6 mb-8">
            <div class="flex items-center justify-between mb-4">
                <h3 class="text-lg font-bold text-gray-900 flex items-center">
                    <svg class="h-5 w-5 text-indigo-600 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    Monthly Operations
                </h3>
                <form method="get" class="flex items-center space-x-2">
                    <!-- Preserve selected_date for daily operations -->
                    <input type="hidden" name="selected_date" value="{{ selected_date|date:'Y-m-d' }}">
                    <label for="selected_month" class="text-sm text-gray-600">Month:</label>
                    <input
                        type="month"
                        id="selected_month"
                        name="selected_month"
                        value="{{ selected_month_start|date:'Y-m' }}"
                        max="{{ today|date:'Y-m' }}"
                        class="px-3 py-1 text-sm border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                        onchange="this.form.submit()"
                    >
                    <button type="button" onclick="document.getElementById('selected_month').value='{{ today|date:'Y-m' }}'; this.form.submit();" class="px-3 py-1 text-sm bg-indigo-500 text-white rounded-lg hover:bg-indigo-600">
                        Current Month
                    </button>
                </form>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
                <!-- 1. Total Adhoc Billing -->
                <a href="{% url 'operations:adhoc_billing_list' %}" class="block group">
                    <div class="text-center p-4 bg-gradient-to-br from-orange-50 to-orange-100 rounded-lg border border-orange-200 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1 cursor-pointer">

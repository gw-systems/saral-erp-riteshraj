# ============================================================================
# CRITICAL SETTINGS - REQUIRED FOR PRODUCTION
# ============================================================================
# Django Settings
SECRET_KEY=your-secret-key-here-must-be-at-least-50-characters-long
DEBUG=False
ALLOWED_HOSTS=your-cloud-run-url.run.app,your-custom-domain.com

# CSRF and Security
CSRF_TRUSTED_ORIGINS=https://your-cloud-run-url.run.app,https://your-custom-domain.com

# Database Configuration
USE_CLOUD_SQL=true
CLOUD_SQL_CONNECTION_NAME=your-project:region:instance-name
DB_NAME=erp
DB_USER=admin
DB_PASSWORD=your-secure-database-password
DB_HOST=/cloudsql/your-project:region:instance-name
DB_PORT=5432

# Google Cloud Tasks Configuration (replaces Celery)
USE_CLOUD_TASKS=true
GCP_LOCATION=us-central1
CLOUD_TASKS_QUEUE=default
CLOUD_TASKS_SERVICE_URL=https://your-cloud-run-url.run.app
GCP_SERVICE_ACCOUNT=your-service-account@your-project.iam.gserviceaccount.com

# Zoho Bigin API Credentials
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
ZOHO_REDIRECT_URI=https://your-cloud-run-url.run.app/oauth2callback/

# Google Cloud Project
GCP_PROJECT_ID=your-gcp-project-id

# ============================================================================
# GMAIL LEADS INTEGRATION (OPTIONAL)
# ============================================================================
# Gmail OAuth credentials - get from Google Cloud Console
# Leave blank to disable Gmail Leads integration
GMAIL_LEADS_CLIENT_ID=your-gmail-leads-client-id
GMAIL_LEADS_CLIENT_SECRET=your-gmail-leads-client-secret

# ============================================================================
# GOOGLE ADS INTEGRATION (OPTIONAL)
# ============================================================================
# Google Ads API credentials - get from Google Ads developer console
# Leave blank to disable Google Ads integration
GOOGLE_ADS_CLIENT_ID=your-google-ads-client-id
GOOGLE_ADS_CLIENT_SECRET=your-google-ads-client-secret
GOOGLE_ADS_DEVELOPER_TOKEN=your-google-ads-developer-token

# ============================================================================
# TALLY ERP INTEGRATION
# ============================================================================
# Tally server connection settings
# Get these from your Tally administrator/accountant
TALLY_HOST=103.251.94.79
TALLY_PORT=10717
TALLY_TIMEOUT=30
TALLY_COMPANY_NAME=

# Optional: For future HTTPS support
# TALLY_USE_HTTPS=False
# TALLY_API_KEY=

# ============================================================================
# ADOBE SIGN E-SIGNATURE INTEGRATION (OPTIONAL)
# ============================================================================
# Adobe Sign OAuth credentials - get from Adobe Sign developer console
# Leave blank to disable Adobe Sign integration
ADOBE_SIGN_CLIENT_ID=your-adobe-client-id-here
ADOBE_SIGN_CLIENT_SECRET=your-adobe-client-secret-here
ADOBE_SIGN_REFRESH_TOKEN=your-refresh-token-here

# Adobe Sign API configuration
ADOBE_SIGN_BASE_URL=https://api.in1.adobesign.com/api/rest/v6

# Director configuration (REQUIRED - must be valid email)
ADOBE_SIGN_DIRECTOR_EMAIL=director@yourcompany.com
ADOBE_SIGN_DIRECTOR_NAME=Vivek Tiwari

# CRITICAL: Webhook security (C2 Fix)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADOBE_SIGN_WEBHOOK_SECRET=generate-random-32-char-secret-here
ENVIRONMENT=development

# Apollo API Key
APOLLO_API_KEY=your-apollo-api-key-here
